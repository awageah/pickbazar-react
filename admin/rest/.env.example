# ─────────────────────────────────────────────────────────────────────────────
# Kolshi Admin Frontend — environment variables
# Target: http://localhost:3002   (whitelisted in backend CORS)
#
# Copy to .env.local and fill in real values before running:
#   cp .env.example .env.local
#
# See ENV_SETUP.md §3 for the full variable reference.
# ─────────────────────────────────────────────────────────────────────────────

# ── Application ──────────────────────────────────────────────────────────────
APPLICATION_MODE=development

# ── Kolshi backend ───────────────────────────────────────────────────────────
# Includes the /api/v1 prefix. Do NOT add a trailing slash.
NEXT_PUBLIC_REST_API_ENDPOINT=http://localhost:8080/api/v1

# Link back to the customer storefront (used in "View on shop" links).
NEXT_PUBLIC_SHOP_URL=http://localhost:3003

# ── Auth (cookie layout) ─────────────────────────────────────────────────────
# Cookie name the Bearer interceptor reads.  Stores the full AuthResponse
# ({ token, permissions, role }) as JSON.  Kept separate from the shop's
# auth_token cookie so a dev can be logged into both apps simultaneously.
NEXT_PUBLIC_AUTH_TOKEN_KEY=AUTH_CRED

# ── i18n ─────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_DEFAULT_LANGUAGE=ar
NEXT_PUBLIC_ENABLE_MULTI_LANG=true
NEXT_PUBLIC_AVAILABLE_LANGUAGES=ar,en

# ── Cloudinary (client-side image upload) ────────────────────────────────────
# Backend does NOT host images — it stores fully-qualified URLs only.
# Create an unsigned upload preset in your Cloudinary console and set it here.
# Reuse the same cloud + preset as the shop app.
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=
NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET=

# ── App version ───────────────────────────────────────────────────────────────
NEXT_PUBLIC_VERSION=1.0.0-kolshi
