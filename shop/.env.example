# ─────────────────────────────────────────────────────────────
# Kolshi Shop Frontend — local development template
# Copy this file to `.env.local` and fill in the blanks.
# Target: http://localhost:3003   (whitelisted in backend CORS)
# ─────────────────────────────────────────────────────────────
#
# Source of truth: ENV_SETUP.md §2

# ── Framework mode ──────────────────────────────────────────
FRAMEWORK_PROVIDER=rest
APPLICATION_MODE=development

# ── Kolshi backend ──────────────────────────────────────────
# Includes the /api/v1 prefix; do NOT add a trailing slash.
NEXT_PUBLIC_REST_API_ENDPOINT=http://localhost:8080/api/v1

# Admin console URL (used by "Sell on Kolshi" CTAs, etc.).
NEXT_PUBLIC_ADMIN_URL=http://localhost:3002

# ── Auth (cookie layout) ────────────────────────────────────
# Cookie name the axios Bearer interceptor reads. Stores the full
# AuthResponse ({ token, permissions, role, expires_in }) as JSON.
NEXT_PUBLIC_AUTH_TOKEN_KEY=auth_token

# ── i18n ────────────────────────────────────────────────────
# Kolshi is Arabic-first; the backend localises error messages via
# the Accept-Language request header. See API_CLIENT_SETUP.md §3.3.
NEXT_PUBLIC_DEFAULT_LANGUAGE=ar
NEXT_PUBLIC_ENABLE_MULTI_LANG=true
NEXT_PUBLIC_AVAILABLE_LANGUAGES=ar,en

# ── Cloudinary (client-side image upload) ───────────────────
# Backend does NOT host images — it stores fully-qualified URLs only.
# Uploader components post directly to Cloudinary's unsigned endpoint.
# Create an unsigned upload preset in your Cloudinary console and name
# it below. See ENV_SETUP.md §5 for preset requirements.
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=
NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET=

# ── App version (shown in footer / bug reports) ─────────────
NEXT_PUBLIC_VERSION=1.0.0-kolshi
